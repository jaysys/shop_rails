#!/usr/bin/env ruby
require "rbconfig"

# Ensure DB exists/migrated when starting the web server directly via `bin/rails s`.
if ENV["SKIP_AUTO_DB_PREPARE"] != "1" && %w[s server].include?(ARGV.first)
  app_root = File.expand_path("..", __dir__)
  Dir.mkdir(File.join(app_root, "storage")) unless Dir.exist?(File.join(app_root, "storage"))

  env = "development"
  ARGV.each_with_index do |arg, index|
    if arg == "-e"
      env = ARGV[index + 1].to_s if ARGV[index + 1]
    elsif arg.start_with?("--environment=")
      env = arg.split("=", 2).last.to_s
    end
  end

  sqlite_path =
    case env
    when "test" then File.join(app_root, "storage", "test.sqlite3")
    when "production" then File.join(app_root, "storage", "production.sqlite3")
    else File.join(app_root, "storage", "development.sqlite3")
    end

  should_prepare = !File.exist?(sqlite_path)

  # If Solid Queue is enabled in Puma, ensure queue tables also exist.
  if !should_prepare && ENV["SOLID_QUEUE_IN_PUMA"] == "true"
    begin
      require "sqlite3"
      db = SQLite3::Database.new(sqlite_path)
      result = db.get_first_value("SELECT name FROM sqlite_master WHERE type = 'table' AND name = 'solid_queue_recurring_tasks'")
      should_prepare = result.to_s != "solid_queue_recurring_tasks"
    rescue StandardError
      should_prepare = true
    ensure
      db&.close
    end
  end

  if should_prepare
    success = system({ "SKIP_AUTO_DB_PREPARE" => "1" }, RbConfig.ruby, __FILE__, "db:prepare")
    abort "Failed to run db:prepare" unless success
  end
end

APP_PATH = File.expand_path("../config/application", __dir__)
require_relative "../config/boot"
require "rails/commands"
