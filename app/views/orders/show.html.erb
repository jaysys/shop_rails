<% content_for :title, "주문 상세" %>

<section>
  <h1>주문 상세</h1>

  <div class="checkout-card">
    <p>주문번호: <strong><%= @order.order_id %></strong></p>
    <p>주문명: <strong><%= @order.order_name %></strong></p>
    <p>결제상태: <strong><%= @order.status %></strong></p>
    <p>결제완료일: <strong><%= @order.updated_at.strftime("%Y-%m-%d %H:%M:%S") %></strong></p>
    <p>결제일시: <strong><%= @order.updated_at.strftime("%Y-%m-%d %H:%M") %></strong></p>
  </div>

  <table class="cart-table">
    <thead>
      <tr>
        <th>상품코드</th>
        <th>상품명</th>
        <th>단가</th>
        <th>수량</th>
        <th>소계</th>
      </tr>
    </thead>
    <tbody>
      <% @order_items.each do |item| %>
        <tr>
          <td><%= item.product_id.present? ? "P-#{item.product_id}" : "-" %></td>
          <td><%= item.product_name %></td>
          <td><%= number_to_currency(item.unit_price) %></td>
          <td><%= item.quantity %></td>
          <td><%= number_to_currency(item.subtotal) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="cart-footer">
    <strong>총 결제금액: <%= number_to_currency(@order.amount, unit: "₩", precision: 0) %></strong>
    <div class="row">
      <%= link_to "PDF 미리보기", order_path(@order, format: :pdf, disposition: "inline"), class: "btn small", target: "_blank", rel: "noopener" %>
      <%= link_to "PDF 저장", order_path(@order, format: :pdf), class: "btn small" %>
      <%= link_to "구매내역 목록", orders_path, class: "text-link" %>
    </div>
  </div>

  <section class="pdf-preview">
    <h2>PDF 미리보기</h2>
    <iframe
      src="<%= order_path(@order, format: :pdf, disposition: "inline") %>"
      title="Order PDF Preview"
      class="pdf-frame"
    ></iframe>
  </section>
</section>
