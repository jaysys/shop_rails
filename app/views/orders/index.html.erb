<% content_for :title, "구매내역" %>

<section>
  <h1>구매내역</h1>

  <% if @orders.empty? %>
    <p class="muted">아직 결제 완료된 주문이 없습니다.</p>
    <%= link_to "상품 보러가기", products_path, class: "text-link" %>
  <% else %>
    <table class="cart-table">
      <thead>
        <tr>
          <th>주문번호</th>
          <th>주문명</th>
          <th>결제금액</th>
          <th>결제일시</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @orders.each do |order| %>
          <tr>
            <td><code><%= order.order_id %></code></td>
            <td><%= order.order_name %></td>
            <td><%= number_to_currency(order.amount, unit: "₩", precision: 0) %></td>
            <td><%= order.updated_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td><%= link_to "상세", order_path(order), class: "text-link" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>
