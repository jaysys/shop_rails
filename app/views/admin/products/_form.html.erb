<section class="product-form-shell">
  <aside class="product-form-summary">
    <h2>상품 미리보기</h2>
    <% if @product.image.attached? %>
      <%= image_tag @product.image, class: "thumb-lg" %>
    <% else %>
      <div class="product-placeholder">No Image</div>
    <% end %>

    <dl>
      <dt>상품명</dt>
      <dd><%= @product.name.presence || "(입력 전)" %></dd>
      <dt>현재 가격</dt>
      <dd><%= @product.price.present? ? number_to_currency(@product.price, unit: "₩", precision: 0) : "(입력 전)" %></dd>
      <% if @product.persisted? %>
        <dt>상품코드</dt>
        <dd>P-<%= @product.id %></dd>
      <% end %>
    </dl>
  </aside>

  <%= form_with model: [:admin, @product], class: "auth-card product-form-card" do |form| %>
    <% if @product.errors.any? %>
      <div class="flash alert"><%= @product.errors.full_messages.join(", ") %></div>
    <% end %>

    <div class="field-block">
      <%= form.label :name, "상품명" %>
      <%= form.text_field :name, required: true, maxlength: 120, placeholder: "예: 클래식 코튼 셔츠" %>
    </div>

    <div class="field-block">
      <%= form.label :price, "가격 (KRW)" %>
      <%= form.number_field :price, required: true, min: 0, step: 0.01, placeholder: "예: 59000" %>
    </div>

    <div class="field-block">
      <%= form.label :description, "설명" %>
      <%= form.text_area :description, rows: 7, required: true, placeholder: "소재, 핏, 권장 스타일 등을 입력하세요." %>
    </div>

    <div class="field-block">
      <%= form.label :category_ids, "카테고리 (복수 선택 가능)" %>
      <div class="category-checkboxes">
        <% @categories.each do |category| %>
          <label class="category-check-item">
            <%= check_box_tag "product[category_ids][]", category.id, @product.category_ids.include?(category.id), id: "product_category_#{category.id}" %>
            <span><%= category.name %></span>
          </label>
        <% end %>
      </div>
      <%= hidden_field_tag "product[category_ids][]", "" %>
    </div>

    <div class="field-block">
      <%= form.label :image, "상품 이미지" %>
      <%= form.file_field :image, accept: "image/*" %>
      <p class="muted">권장 비율: 1:1 또는 4:5, 최소 800px 이상</p>
    </div>

    <div class="row">
      <%= form.submit @product.persisted? ? "수정 저장" : "상품 등록", class: "btn" %>
      <%= link_to "취소", admin_products_path, class: "text-link" %>
    </div>
  <% end %>
</section>
