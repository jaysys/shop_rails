<% content_for :title, "관리자 - 문의 관리" %>

<section>
  <h1>문의 관리</h1>

  <div class="admin-tabs">
    <%= link_to "전체", admin_complaints_path, class: "admin-tab #{'active' if @status.blank?}" %>
    <% Complaint::STATUSES.each do |status| %>
      <%= link_to Complaint::STATUS_LABELS.fetch(status, status), admin_complaints_path(status: status), class: "admin-tab #{'active' if @status == status}" %>
    <% end %>
  </div>

  <% if @complaints.blank? %>
    <p class="muted">해당 상태의 문의가 없습니다.</p>
  <% else %>
    <table class="cart-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>사용자</th>
          <th>제목</th>
          <th>주문번호</th>
          <th>상태</th>
          <th>등록일</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @complaints.each do |complaint| %>
          <tr>
            <td><%= complaint.id %></td>
            <td><%= complaint.user&.email || "-" %></td>
            <td><%= complaint.title %></td>
            <td><%= complaint.order&.order_id || "-" %></td>
            <td><span class="status-badge <%= complaint.status %>"><%= complaint.status_label %></span></td>
            <td><%= complaint.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td><%= link_to "상세/처리", admin_complaint_path(complaint), class: "text-link" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>
