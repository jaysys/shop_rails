<% content_for :title, "회원가입" %>

<section class="auth-shell">
  <div class="auth-intro">
    <p class="auth-kicker">Create Account</p>
    <h1>회원가입</h1>
    <p class="muted">기본 정보와 비밀번호를 입력해 계정을 생성하세요.</p>
  </div>

  <div class="auth-card auth-panel">
    <%= form_with model: @user, class: "auth-form" do |form| %>
      <% if @user.errors.any? %>
        <div class="flash alert">
          <%= @user.errors.full_messages.join(", ") %>
        </div>
      <% end %>

      <div class="field-block">
        <%= form.label :name, "이름" %>
        <%= form.text_field :name, required: true, maxlength: 80, autofocus: true, placeholder: "이름을 입력하세요" %>
      </div>

      <div class="field-block">
        <%= form.label :email, "이메일" %>
        <%= form.email_field :email, required: true, autocomplete: "email", placeholder: "name@example.com" %>
      </div>

      <div class="field-block">
        <%= form.label :password, "비밀번호" %>
        <%= form.password_field :password, required: true, minlength: 8, autocomplete: "new-password", placeholder: "8자 이상 입력" %>
      </div>

      <div class="field-block">
        <%= form.label :password_confirmation, "비밀번호 확인" %>
        <%= form.password_field :password_confirmation, required: true, minlength: 8, autocomplete: "new-password", placeholder: "비밀번호를 다시 입력" %>
      </div>

      <p class="auth-policy muted">비밀번호는 최소 8자 이상이어야 합니다.</p>
      <%= form.submit "회원가입", class: "btn auth-submit" %>
    <% end %>

    <div class="auth-footnote">
      <span class="muted">이미 계정이 있나요?</span>
      <%= link_to "로그인", login_path, class: "text-link" %>
    </div>
  </div>
</section>
