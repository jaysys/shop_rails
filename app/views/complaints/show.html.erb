<% content_for :title, "문의 상세" %>

<section>
  <div class="row">
    <h1>문의 상세</h1>
    <%= link_to "목록", complaints_path, class: "text-link" %>
  </div>

  <div class="checkout-card">
    <p>문의번호: <strong>#<%= @complaint.id %></strong></p>
    <p>제목: <strong><%= @complaint.title %></strong></p>
    <p>상태: <span class="status-badge <%= @complaint.status %>"><%= @complaint.status_label %></span></p>
    <p>주문번호: <strong><%= @complaint.order&.order_id || "-" %></strong></p>
    <p>등록일: <strong><%= @complaint.created_at.strftime("%Y-%m-%d %H:%M:%S") %></strong></p>
    <% if @complaint.resolved_at.present? %>
      <p>처리일: <strong><%= @complaint.resolved_at.strftime("%Y-%m-%d %H:%M:%S") %></strong></p>
    <% end %>

    <hr class="profile-divider">
    <h2>문의 내용</h2>
    <p><%= simple_format(@complaint.content) %></p>

    <% if @complaint.attachment.attached? %>
      <h2>첨부 이미지</h2>
      <%= image_tag @complaint.attachment, class: "product-image-lg" %>
    <% end %>

    <% if @complaint.admin_reply.present? %>
      <hr class="profile-divider">
      <h2>관리자 답변</h2>
      <p><%= simple_format(@complaint.admin_reply) %></p>
    <% end %>
  </div>
</section>
